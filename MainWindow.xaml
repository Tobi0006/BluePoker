<Window x:Class="BluePoker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BluePoker - Premium Poker Platform"
        Width="1280" Height="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <Color x:Key="Electric">#3B82F6</Color>
        <Color x:Key="ElectricLight">#60A5FA</Color>
        <Color x:Key="Gold">#C9A84C</Color>
        <Color x:Key="TextPrimary">#E8ECF4</Color>
        <Color x:Key="TextDim">#9CA3AF</Color>

        <SolidColorBrush x:Key="ElectricBrush" Color="{StaticResource Electric}"/>
        <SolidColorBrush x:Key="ElectricLightBrush" Color="{StaticResource ElectricLight}"/>
        <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource Gold}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}"/>

        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#0F1535"/>
            <Setter Property="Foreground" Value="#E8ECF4"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="CaretBrush" Value="#60A5FA"/>
        </Style>

        <Style x:Key="DarkPassword" TargetType="PasswordBox">
            <Setter Property="Background" Value="#0F1535"/>
            <Setter Property="Foreground" Value="#E8ECF4"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="CaretBrush" Value="#60A5FA"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="0"
                                BorderBrush="#3B82F6" BorderThickness="1.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2563EB" Offset="0"/>
                                    <GradientStop Color="#1D4ED8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#2563EB" BlurRadius="14" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform>
                                        <ScaleTransform x:Name="contentScale" ScaleX="1" ScaleY="1"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                                <!-- Shine sweep overlay -->
                                <Border x:Name="shine" Background="Transparent" IsHitTestVisible="False">
                                    <Border.OpacityMask>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="#30FFFFFF" Offset="0.5"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.OpacityMask>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[0].(GradientStop.Color)" To="#3B82F6" Duration="0:0:0.25"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[1].(GradientStop.Color)" To="#2563EB" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="28" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.6" Duration="0:0:0.25"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[0].(GradientStop.Color)" To="#2563EB" Duration="0:0:0.25"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[1].(GradientStop.Color)" To="#1D4ED8" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="14" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.4" Duration="0:0:0.25"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.MouseDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="contentScale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.1" AutoReverse="True"/>
                                        <DoubleAnimation Storyboard.TargetName="contentScale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.1" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Button.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#3B82F6" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.15" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="1.2"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.15" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="1.2"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="Transparent" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="0.85" Duration="0:0:0.08" AutoReverse="True"/>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="0.85" Duration="0:0:0.08" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButton" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent">
                            <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="#EF4444"
                                              RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Button.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#EF4444" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="cp" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)" To="#FFFFFF" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.15" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="1.2"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.15" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="1.2"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="Transparent" Duration="0:0:0.25"/>
                                        <ColorAnimation Storyboard.TargetName="cp" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)" To="#EF4444" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="0.85" Duration="0:0:0.08" AutoReverse="True"/>
                                        <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="0.85" Duration="0:0:0.08" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#3B82F6" BorderThickness="1" Background="#0A0E27"
            CornerRadius="12" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#0D1228"
                    BorderBrush="#3B82F6" BorderThickness="0,0,0,0.3"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="♠  BLUEPOKER" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource GoldBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="  Premium Poker Platform" FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="─" Style="{StaticResource TitleBarButton}"
                                Click="MinimizeButton_Click" FontSize="16" Foreground="#9CA3AF"/>
                        <Button Content="X" Style="{StaticResource TitleBarCloseButton}"
                            Click="CloseButton_Click" FontSize="14" Margin="0,0,12,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="12,8,12,12">
                <Grid.Background>
                    <RadialGradientBrush Center="0.35,0.5" RadiusX="0.9" RadiusY="0.9">
                        <GradientStop Color="#1E3A8A" Offset="0"/>
                        <GradientStop Color="#0F1535" Offset="0.6"/>
                        <GradientStop Color="#0A0E27" Offset="1"/>
                    </RadialGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Carousel (80%) -->
                <Border x:Name="CarouselBorder" Grid.Column="0"
                        ClipToBounds="True" Background="Transparent"
                        SizeChanged="CarouselBorder_SizeChanged">
                    <Grid>
                        <Canvas x:Name="CarouselCanvas">
                            <Image x:Name="Slide1" Source="landing1.png" Stretch="UniformToFill"
                                   Canvas.Left="0" Canvas.Top="0">
                                <Image.Effect>
                                    <BlurEffect Radius="3"/>
                                </Image.Effect>
                            </Image>
                            <Image x:Name="Slide2" Source="landing4.png" Stretch="UniformToFill"
                                   Canvas.Left="0" Canvas.Top="0" Visibility="Collapsed">
                                <Image.Effect>
                                    <BlurEffect Radius="3"/>
                                </Image.Effect>
                            </Image>
                            <Image x:Name="Slide3" Source="landing3.png" Stretch="UniformToFill"
                                   Canvas.Left="0" Canvas.Top="0" Visibility="Collapsed">
                                <Image.Effect>
                                    <BlurEffect Radius="3"/>
                                </Image.Effect>
                            </Image>
                        </Canvas>

                        <TextBlock x:Name="SlideTitle" Text="PREMIUM POKER EXPERIENCE"
                                   FontSize="32" FontWeight="Bold" Foreground="#FFFFFF"
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   TextAlignment="Center" Margin="0,226,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="SlideSubtitle" Text="Play with the world's best poker legends"
                                   FontSize="16" FontStyle="Italic" Foreground="#C9D8F8"
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   TextAlignment="Center" Margin="0,261,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="5" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse x:Name="Dot1" Width="10" Height="10" Margin="5,0"
                                     Fill="White" Opacity="0.35"/>
                            <Ellipse x:Name="Dot2" Width="10" Height="10" Margin="5,0"
                                     Fill="{StaticResource ElectricBrush}" Opacity="0.35"/>
                            <Ellipse x:Name="Dot3" Width="10" Height="10" Margin="5,0"
                                     Fill="White" Opacity="0.35"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT: Login Card (20%) -->
                <Border Grid.Column="2" Background="#141E4A"
                        BorderBrush="#3B82F6" BorderThickness="0.3" Padding="20"
                        Margin="8,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Image Source="logo.png" Width="192" Height="174"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock Text="BLUEPOKER" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource GoldBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock Text="WELCOME TO THE FIRT PLACE" FontSize="13"
                                       FontWeight="Bold" Foreground="{StaticResource ElectricLightBrush}"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <Rectangle Height="1" Fill="#3B82F6" Opacity="0.3" Margin="0,12,0,0"/>
                            <TextBlock Text="EMAIL" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource ElectricLightBrush}" Margin="0,14,0,4"/>
                            <TextBox x:Name="EmailInput" Style="{StaticResource DarkInput}" Height="38"/>
                            <TextBlock Text="PASSWORD" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource ElectricLightBrush}" Margin="0,12,0,4"/>
                            <PasswordBox x:Name="PasswordInput" Style="{StaticResource DarkPassword}" Height="38"/>
                            <Button x:Name="SubmitButton" Content="LOGIN"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SubmitButton_Click" Margin="0,35,0,0"/>
                            <TextBlock x:Name="LoginError" Text="Something went wrong"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#EF4444"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>